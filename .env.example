# Copiare in .env e valorizzare. Non committare mai .env.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Chiave master Fernet per la cifratura delle credenziali router (Fase 1).
# Generare con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

DB_NAME=mkremote
DB_USER=mkremote
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Channels (Fase 6: terminale SSH nel browser) — stesso Redis di Celery, DB separato.
CHANNELS_REDIS_URL=redis://localhost:6379/1

# Pianificazione subnet VPN WireGuard hub-and-spoke (Fase 0 / Fase 2).
VPN_SUBNET_CIDR=10.10.0.0/24
VPN_HUB_IP=10.10.0.1
VPN_PERSONAL_IP_RANGE_START=10.10.0.2
VPN_PERSONAL_IP_RANGE_END=10.10.0.9
VPN_ROUTER_IP_RANGE_START=10.10.0.10

# Hub WireGuard sul VPS (Fase 2) — da valorizzare quando il VPS sarà provisionato.
VPN_HUB_PUBLIC_ENDPOINT=
VPN_HUB_PUBLIC_PORT=51820
VPN_HUB_PUBLIC_KEY=

# Accesso SSH al VPS per gestire i peer WireGuard (wg set / wg syncconf).
VPS_SSH_HOST=
VPS_SSH_PORT=22
VPS_SSH_USER=root
VPS_SSH_PRIVATE_KEY_PATH=
VPN_WG_INTERFACE=wg0
VPN_WG_CONF_PATH=/etc/wireguard/wg0.conf

# Spazio FTPS Aruba per i backup router (Fase 4).
BACKUP_FTP_HOST=
BACKUP_FTP_PORT=21
BACKUP_FTP_USER=
BACKUP_FTP_PASSWORD=
BACKUP_FTP_BASE_PATH=mikrotik-backups
