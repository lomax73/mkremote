# Copiare in .env e valorizzare. Non committare mai .env.

DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Chiave master Fernet per la cifratura delle credenziali router (Fase 1).
# Generare con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

DB_NAME=mkremote
DB_USER=mkremote
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Pianificazione subnet VPN WireGuard hub-and-spoke (Fase 0 / Fase 2).
VPN_SUBNET_CIDR=10.10.0.0/24
VPN_HUB_IP=10.10.0.1
VPN_PERSONAL_IP_RANGE_START=10.10.0.2
VPN_PERSONAL_IP_RANGE_END=10.10.0.9
VPN_ROUTER_IP_RANGE_START=10.10.0.10
